# ═══════════════════════════════════════════════════════════════
# WispHub Admin - Variables de entorno
# Copia a .env y completa con tus valores reales
# NO commitear .env al repositorio
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE ───
# Local: file:./data.db
# Cloud con volume: file:/app/data/data.db
DATABASE_URL="file:./data.db"

# ─── WISPHUB ───
WISPHUB_API_KEY=""

# ─── SERVER ───
PORT=7400
NODE_ENV="production"

# ─── PIN ACCESO ───
ACCESS_PIN=""

# ─── MIKROTIK ───
# Local: 192.168.10.1
# Desde nube: tu IP publica (154.88.128.161)
MIKROTIK_HOST=""
MIKROTIK_USER=""
MIKROTIK_PASS=""
MIKROTIK_PORT="8728"

# ─── ALLOWED IPS para MikroTik ───
# IPs que pueden conectarse al MikroTik (tu IP, IPs de la nube, etc)
# Render outbound IPs: 35.160.120.126, 44.233.151.27, 54.184.196.143
# Railway: usa rangos AWS us-east-1
ALLOWED_IPS="35.160.120.126,44.233.151.27,54.184.196.143"
