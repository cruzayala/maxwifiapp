# ═══════════════════════════════════════════════════════════════
# WispHub Admin - Variables de entorno
# Copia este archivo a .env y completa con tus valores
# NUNCA commitear .env al repositorio
# ═══════════════════════════════════════════════════════════════

# Base de datos SQLite (local)
# En Railway con Volume montado: file:/app/data/data.db
DATABASE_URL="file:./data.db"

# WispHub API Key (obtener en wisphub.io/staff/)
WISPHUB_API_KEY=""

# Puerto del servidor
# Local: 7400 produccion, 7401 development
# Railway/Render: usa $PORT automaticamente
PORT=7400

# PIN de acceso a la app (4-8 digitos)
# Si esta vacio, no se requiere PIN
ACCESS_PIN=""

# Modo (development | production)
NODE_ENV="production"
