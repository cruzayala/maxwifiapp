# ═══════════════════════════════════════════════════════════════
# WispHub Admin - Variables de entorno
# Copia a .env y completa con tus valores reales
# NO commitear .env al repositorio
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE ───
# Local/Railway: PostgreSQL. En Railway usa la variable del plugin PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── WISPHUB ───
WISPHUB_API_KEY=""

# ─── SERVER ───
# Railway asigna PORT automaticamente; en local usa 7400 o 7402
PORT=7400
NODE_ENV="production"

# ─── AUTENTICACION ───
# El sistema usa usuarios con clave (tabla User en BD).
# En produccion son obligatorias si la tabla User esta vacia.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-esta-clave-larga"
ADMIN_FULL_NAME="Super Administrador"

# ─── MIKROTIK ───
# Desde Railway: usa la IP publica del MikroTik (154.88.128.162-165)
# Desde LAN:     192.168.10.1 / 192.168.13.1
MIKROTIK_HOST=""
MIKROTIK_USER=""
MIKROTIK_PASS=""
MIKROTIK_PORT="8728"

# ─── CAPTIVE PORTAL ───
# Cuando se bloquea un cliente, el MikroTik redirige TCP/80 a este host:port
# CAPTIVE_AUTOCONFIG=true: al boot el server detecta su IP publica via ipify
#   y reescribe las reglas NAT del MikroTik. Ideal para Railway (IP cambia).
# Si lo dejas en false, debes ejecutar setup manual con tu IP publica.
CAPTIVE_AUTOCONFIG="true"
CAPTIVE_PORT="7400"

# ─── ALLOWED IPS para MikroTik (informativo, lo aplicas en MikroTik) ───
# Rangos AWS us-east-1 para Railway:
ALLOWED_IPS="35.160.120.126,44.233.151.27,54.184.196.143,52.0.0.0/15,3.80.0.0/12,44.192.0.0/10"

# ─── SYNC LOOP ───
# Cada cuanto sincronizar Wisphub + MikroTik a la BD local (ms)
SYNC_INTERVAL_MS="120000"

# ─── FACTURACION POR WHATSAPP ───
# Nombre del negocio que aparece en la factura
INVOICE_BUSINESS_NAME="MaxWifi"
# Telefono de soporte que aparece en la factura
SUPPORT_PHONE=""
# Bancos / metodos de pago - separar con | (pipe)
INVOICE_BANK_INFO="Banco BHD: 1234567890 - MaxWifi SRL|BanReservas: 9876543210|Transferencia: 829-XXX-XXXX"

# ─── WHATSAPP NOTIFICACIONES AUTOMATICAS ───
NOTIF_ENABLED="false"
NOTIF_RUN_HOUR="10"

# ─── AUTO-BLOQUEO POR MORA ───
AUTO_BLOCK_ENABLED="false"
AUTO_BLOCK_MOROSO_DAYS="0"
AUTO_BLOCK_HARD_DAYS="7"
AUTO_BLOCK_RUN_HOUR="9"

# ─── WEB ACTIVITY TRACKING (DNS log) ───
WEB_ACTIVITY_ENABLED="true"
WEB_ACTIVITY_POLL_MS="60000"
WEB_ACTIVITY_KEEP_DAYS="30"
