{
  "name": "wisp-rd",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "concurrently \"npm:start\" \"npm:server:dev\"",
    "server:dev": "cross-env NODE_ENV=development node server.js",
    "server": "node server.js",
    "start:prod": "npx prisma db push --accept-data-loss --skip-generate && node server.js",
    "build": "ng build",
    "prod": "npm run build && node server.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma db push --skip-generate"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@angular/router": "21.2.11",
    "@prisma/client": "^6.19.3",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "maplibre-gl": "^4.7.1",
    "node-routeros": "^1.6.8",
    "prisma": "^6.19.3",
    "qrcode-terminal": "^0.12.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.11",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
